}

uint16 HelmetForArmor(uint16 armorPid)
{
    switch(armorPid)
    {
    case PID_LEATHER_JACKET: return PID_LEATHER_JACKET_HELMET;
    case PID_LEATHER_ARMOR_MK_II: return PID_LEATHER_ARMOR_HELMET_MK2;
    case PID_CURED_LEATHER_ARMOR: return PID_LEATHER_ARMOR_HELMET;
    case PID_METAL_ARMOR_MK_II: return PID_METAL_HELMET_MK2;
    case PID_TESLA_ARMOR: return PID_TESLA_HELMET;
    case PID_COMBAT_ARMOR: return PID_COMBAT_HELMET;
    case PID_COMBAT_ARMOR_MK_II: return PID_COMBAT_HELMET_MK_II;
    case PID_BROTHERHOOD_COMBAT_ARMOR: return PID_BROTHERHOOD_HELMET;
    case PID_NCR_ARMOR: return PID_NCR_HELMET;
    case PID_ENVIROMENTAL_ARMOR: return PID_METAL_HELMET;
    case PID_ENCLAVE_COMBAT_ARMOR: return PID_ENCLAVE_COMBAT_HELMET;
    case PID_VAULT_13_SUIT: return PID_MOTORCYCLE_HELMET;
    case PID_VAULT_SUIT: return PID_MOTORCYCLE_HELMET;
    case PID_SF_COMBAT_JACKET: return PID_COMBAT_LEATHER_JACKET_HELMET;
    case PID_DESERT_COMBAT_ARMOR: return PID_DESERT_COMBAT_HELMET;
    }
    return PID_COMBAT_HELMET;
}


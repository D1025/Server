uint16 RandomWeaponPidWithAmmo()
{
    // Keep the "weapon + ammo" guarantee by rerolling until a valid ammo weapon is found.
    for(uint i = 0; i < 25; i++)
    {
        uint16 pid = RandomWeaponPidFromList();
        ProtoItem@ proto = GetProtoItem(pid);
        if(valid(proto) && proto.Weapon_DefaultAmmoPid != 0 && proto.Weapon_MaxAmmoCount > 0)
            return pid;
    }
    return PID_10MM_PISTOL;
}

uint16 RandomArmorPid()
{
    switch(Random(1, 15))
    {
    case 1: return PID_LEATHER_JACKET;
    case 2: return PID_LEATHER_ARMOR_MK_II;
    case 3: return PID_CURED_LEATHER_ARMOR;
    case 4: return PID_METAL_ARMOR_MK_II;
    case 5: return PID_TESLA_ARMOR;
    case 6: return PID_COMBAT_ARMOR;
    case 7: return PID_COMBAT_ARMOR_MK_II;
    case 8: return PID_BROTHERHOOD_COMBAT_ARMOR;
    case 9: return PID_NCR_ARMOR;
    case 10: return PID_ENVIROMENTAL_ARMOR;
    case 11: return PID_ENCLAVE_COMBAT_ARMOR;
    case 12: return PID_VAULT_13_SUIT;
    case 13: return PID_VAULT_SUIT;
    case 14: return PID_SF_COMBAT_JACKET;
    case 15: return PID_DESERT_COMBAT_ARMOR;

// Item upgrades / quality / perks

#ifndef __ITEM_BONUS__
#define __ITEM_BONUS__

#include "_macros.fos"
#include "_defines.fos"
#include "item_upgrades_shared.fos"
#include "lexems_h.fos"

const string ITEM_LEXEM_CUSTOM_NAME = "$-";
const string ITEM_LEXEM_LEGENDARY = "$legendary";
const uint BASE_WEAPON_PERKS = 3;

int SlotsToType(Item@ it, uint slot)
{
    return UpgradeSlotType(it, slot);
}

int SlotsToValue(Item@ it, uint slot)
{
    return UpgradeSlotValue(it, slot);
}

int SlotRaw(Item@ it, uint slot)
{
    switch(slot)
    {
    case 0:
        return it.Val0;
    case 1:
        return it.Val1;
    case 2:
        return it.Val2;
    case 3:
        return it.Val3;
    case 4:
        return it.Val4;
    case 5:
        return it.Val5;
    case 6:
        return it.Val6;
    default:
        return 0;
    }
    return 0;
}

void SetSlotRaw(Item@ it, uint slot, int raw)
{
    switch(slot)
    {
    case 0:
        it.Val0 = raw;
        return;
    case 1:
        it.Val1 = raw;
        return;
    case 2:
        it.Val2 = raw;
        return;
    case 3:
        it.Val3 = raw;
        return;
    case 4:
        it.Val4 = raw;
        return;
    case 5:
        it.Val5 = raw;
        return;
    case 6:
        it.Val6 = raw;
        return;
    default:
        return;
    }
}

void SetSlotType(Item@ it, uint slot, int value)
{
    int raw = value;
    if(value != 0 && !UpgradeIsSlotMarker(value))
    {
        int currentValue = SlotsToValue(it, slot);
        raw = UpgradePackSlotData(value, currentValue);
    }
    SetSlotRaw(it, slot, raw);
}

void SetSlotValue(Item@ it, uint slot, int value)
{
    int currentType = SlotsToType(it, slot);
    if(currentType == 0 || UpgradeIsSlotMarker(currentType))
        SetSlotRaw(it, slot, currentType);
    else
        SetSlotRaw(it, slot, UpgradePackSlotData(currentType, value));
}

void ResetUpgradeSlots(Item@ it, uint slotsCount)
{
    if(valid(it))
    {
        if(UpgradeItemIsHelmet(it))
            slotsCount = 0;

        uint baseSlots = slotsCount;
        int extraSlots = UpgradeExtraSlotsFromProto(it.Proto);
        if(extraSlots > 0)
        {
            if(baseSlots >= 5)
                slotsCount = UPGRADE_MAX_SLOTS;
            else
                slotsCount += uint(extraSlots);
        }
    }

    slotsCount = CLAMP(slotsCount, 0, UPGRADE_MAX_SLOTS);
    for(uint i = 0; i < UPGRADE_MAX_SLOTS; i++)
    {
        SetSlotType(it, i, i < slotsCount ? UPGRADE_SLOT_EMPTY : 0);
        SetSlotValue(it, i, 0);
    }
    it.Update();
}

uint QualityByRoll_Default(int roll)
{
    uint q = 0;
    if(roll >= 50) q++;
    if(roll >= 60) q++;
    if(roll >= 70) q++;
    if(roll >= 80) q++;
    if(roll >= 90) q++;
    return q;
}

uint QualityByRoll_LowSpecial(int roll)
{
    uint q = 0;
    if(roll >= 0)  q++;
    if(roll > 34)  q++;
    if(roll > 59)  q++;
    if(roll > 74)  q++;
    if(roll > 84)  q++;
    return q;
}

uint QualityByRoll_Crafted(int roll)
{
    uint q = 0;
    if(roll > 55) q++;
    if(roll > 76) q++;
    if(roll > 88) q++;
    if(roll > 95) q++;
    if(roll == 99) q++;
    return q;
}

uint CraftedPerksByRoll(int roll)
{
    if(roll < 35) return 0;
    if(roll < 60) return 1;
    if(roll < 70) return 2;
    if(roll < 80) return 3;
    if(roll < 90) return 4;
    return 5;
}

uint EnsureWeaponBaseQuality(uint quality)
{
    if(quality < BASE_WEAPON_PERKS)
        return BASE_WEAPON_PERKS;
    return quality;
}

bool IsArmorBonusType(int bonusType)
{
    switch(bonusType)
    {
    case BONUS_ARMOR_NORMAL_DT:
    case BONUS_ARMOR_LASER_DT:
    case BONUS_ARMOR_FIRE_DT:
    case BONUS_ARMOR_PLASMA_DT:
    case BONUS_ARMOR_EXPLODE_DT:
    case BONUS_ARMOR_NORMAL_DR:
    case BONUS_ARMOR_LASER_DR:
    case BONUS_ARMOR_FIRE_DR:
    case BONUS_ARMOR_PLASMA_DR:
    case BONUS_ARMOR_EXPLODE_DR:
    case BONUS_ARMOR_CRIT_CHANCE:
    case BONUS_ARMOR_CRIT_POWER:
    case BONUS_ARMOR_MAX_AP:
    case BONUS_ARMOR_RAD_RES:
    case BONUS_ARMOR_POISON_RES:
    case BONUS_ARMOR_ALL_DR:
    case BONUS_ARMOR_STRENGTH:
    case BONUS_ARMOR_PERCEPTION:
    case BONUS_ARMOR_ENDURANCE:
    case BONUS_ARMOR_CHARISMA:
    case BONUS_ARMOR_INTELLIGENCE:
    case BONUS_ARMOR_AGILITY:
    case BONUS_ARMOR_LUCK:
        return true;
    default:
        return false;
    }

    return false;
}

uint ArmorPerkCost(int bonusType)
{
    switch(bonusType)
    {
    case BONUS_ARMOR_NORMAL_DT:
    case BONUS_ARMOR_LASER_DT:
    case BONUS_ARMOR_FIRE_DT:
    case BONUS_ARMOR_PLASMA_DT:
    case BONUS_ARMOR_EXPLODE_DT:
    case BONUS_ARMOR_NORMAL_DR:
    case BONUS_ARMOR_LASER_DR:
    case BONUS_ARMOR_FIRE_DR:
    case BONUS_ARMOR_PLASMA_DR:
    case BONUS_ARMOR_EXPLODE_DR:
    case BONUS_ARMOR_RAD_RES:
    case BONUS_ARMOR_POISON_RES:
    case BONUS_ARMOR_ALL_DR:
        return 1;
    case BONUS_ARMOR_STRENGTH:
    case BONUS_ARMOR_PERCEPTION:
    case BONUS_ARMOR_ENDURANCE:
    case BONUS_ARMOR_CHARISMA:
    case BONUS_ARMOR_INTELLIGENCE:
    case BONUS_ARMOR_AGILITY:
    case BONUS_ARMOR_LUCK:
    case BONUS_ARMOR_CRIT_CHANCE:
    case BONUS_ARMOR_CRIT_POWER:
        return 2;
    case BONUS_ARMOR_MAX_AP:
        return 3;
    default:
        return 0;
    }

    return 0;
}

bool HasBonusAlready(Item@ it, int bonusType)
{
    for(uint i = 0; i < UPGRADE_MAX_SLOTS; i++)
    {
        if(SlotsToType(it, i) == bonusType)
            return true;
    }
    return false;
}

bool TryApplyPerk(Item@ it, int perkType, int perkValue, uint slotCost)
{
    if(!valid(it) || perkType == 0 || slotCost == 0)
        return false;

    if(UpgradeItemIsHelmet(it))
        return false;

    bool isWeaponUpgrade = IsWeaponUpgradePerk(perkType);

    if(UpgradeFreeSlots(it) < int(slotCost))
        return false;

    int perkSlot = -1;
    int rest = int(slotCost) - 1;
    for(uint i = 0; i < UPGRADE_MAX_SLOTS; i++)
    {
        if(SlotsToType(it, i) != UPGRADE_SLOT_EMPTY)
            continue;

        if(perkSlot < 0)
            perkSlot = int(i);
        else if(rest > 0)
        {
            SetSlotType(it, i, UPGRADE_SLOT_USED);
            SetSlotValue(it, i, 0);
            rest--;
        }

        if(rest == 0 && perkSlot >= 0)
            break;
    }

    if(perkSlot < 0 || rest != 0)
        return false;

    SetSlotType(it, uint(perkSlot), perkType);
    SetSlotValue(it, uint(perkSlot), perkValue);
    it.Update();
    return true;
}

bool TryFillUpgradeSlotsRandomly(Item@ it, bool weapon, bool isCrafting = false)
{
    if(!valid(it))
        return false;

    bool appliedAny = false;
    uint safety = 0;
    while(UpgradeFreeSlots(it) > 0 && safety < 300)
    {
        bool applied = weapon ? TryApplyRandomWeaponPerkUniform(it, isCrafting) : TryApplyRandomArmorPerkUniform(it);
        if(!applied)
            break;

        appliedAny = true;
        safety++;
    }

    return appliedAny;
}

bool TryFillUpgradeSlotsWeighted(Item@ it, bool weapon, bool isCrafting = false)
{
    if(!valid(it))
        return false;

    bool appliedAny = false;
    uint safety = 0;
    while(UpgradeFreeSlots(it) > 0 && safety < 300)
    {
        bool applied = weapon ? TryApplyRandomWeaponPerkWeighted(it, isCrafting) : TryApplyRandomArmorPerkWeighted(it);
        if(!applied)
            break;

        appliedAny = true;
        safety++;
    }

    return appliedAny;
}

int RollArmorBonusValue(int bonusType)
{
    switch(bonusType)
    {
    case BONUS_ARMOR_NORMAL_DT:
    case BONUS_ARMOR_LASER_DT:
    case BONUS_ARMOR_FIRE_DT:
    case BONUS_ARMOR_PLASMA_DT:
    case BONUS_ARMOR_EXPLODE_DT:
        return 2;
    case BONUS_ARMOR_NORMAL_DR:
    case BONUS_ARMOR_LASER_DR:
    case BONUS_ARMOR_FIRE_DR:
    case BONUS_ARMOR_PLASMA_DR:
    case BONUS_ARMOR_EXPLODE_DR:
        return 3;
    case BONUS_ARMOR_ALL_DR:
        return 1;
    case BONUS_ARMOR_RAD_RES:
    case BONUS_ARMOR_POISON_RES:
        return 10;
    case BONUS_ARMOR_CRIT_CHANCE:
    case BONUS_ARMOR_CRIT_POWER:
        return -10;
    case BONUS_ARMOR_MAX_AP:
    case BONUS_ARMOR_STRENGTH:
    case BONUS_ARMOR_PERCEPTION:
    case BONUS_ARMOR_ENDURANCE:
    case BONUS_ARMOR_CHARISMA:
    case BONUS_ARMOR_INTELLIGENCE:
    case BONUS_ARMOR_AGILITY:
    case BONUS_ARMOR_LUCK:
        return 1;
    default:
        return 0;
    }

    return 0;
}


{
    BONUS_ARMOR_NORMAL_DT,
    BONUS_ARMOR_LASER_DT,
    BONUS_ARMOR_FIRE_DT,
    BONUS_ARMOR_PLASMA_DT,
    BONUS_ARMOR_EXPLODE_DT,
    BONUS_ARMOR_NORMAL_DR,
    BONUS_ARMOR_LASER_DR,
    BONUS_ARMOR_FIRE_DR,
    BONUS_ARMOR_PLASMA_DR,
    BONUS_ARMOR_EXPLODE_DR,
    BONUS_ARMOR_ALL_DR,
    BONUS_ARMOR_RAD_RES,
    BONUS_ARMOR_POISON_RES,
    BONUS_ARMOR_CRIT_CHANCE,
    BONUS_ARMOR_CRIT_POWER,
    BONUS_ARMOR_MAX_AP,
    BONUS_ARMOR_STRENGTH,
    BONUS_ARMOR_PERCEPTION,
    BONUS_ARMOR_ENDURANCE,
    BONUS_ARMOR_CHARISMA,
    BONUS_ARMOR_INTELLIGENCE,
    BONUS_ARMOR_AGILITY,
    BONUS_ARMOR_LUCK
};

int[] HelmetPerkPool =
{
    BONUS_ARMOR_NORMAL_DT,
    BONUS_ARMOR_LASER_DT,
    BONUS_ARMOR_FIRE_DT,
    BONUS_ARMOR_PLASMA_DT,
    BONUS_ARMOR_EXPLODE_DT,
    BONUS_ARMOR_NORMAL_DR,
    BONUS_ARMOR_LASER_DR,
    BONUS_ARMOR_FIRE_DR,
    BONUS_ARMOR_PLASMA_DR,
    BONUS_ARMOR_EXPLODE_DR,
    BONUS_ARMOR_ALL_DR,
    BONUS_ARMOR_CRIT_CHANCE,
    BONUS_ARMOR_CRIT_POWER
};

int PickArmorPerkType(Item@ it)
{
    int[]@ pool = @ArmorPerkPool;
    if(it.GetProtoId() >= 725 && it.GetProtoId() <= 741)
        @pool = @HelmetPerkPool;

    if(pool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    uint safety = 0;
    while(safety < 200)
    {
        int bonusType = pool[Random(0, pool.length() - 1)];
        if(int(ArmorPerkCost(bonusType)) <= freeSlots)
            return bonusType;
        safety++;
    }

    return 0;
}

bool TryApplyRandomArmorPerk(Item@ it)
{
    int perkType = PickArmorPerkType(it);
    if(perkType == 0)
        return false;

    uint cost = ArmorPerkCost(perkType);
    if(cost == 0)
        return false;

    int value = RollArmorBonusValue(perkType);
    return TryApplyPerk(it, perkType, value, cost);
}

uint UpgradePerkRollWeight(uint cost)
{
    switch(cost)
    {
    case 1:
        return 6;
    case 2:
        return 3;
    case 3:
        return 1;
    default:
        return 0;
    }

    return 0;
}

int PickUniformArmorPerkType(Item@ it)
{
    int[]@ pool = @ArmorPerkPool;
    if(it.GetProtoId() >= 725 && it.GetProtoId() <= 741)
        @pool = @HelmetPerkPool;

    if(pool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    int[] candidates;
    for(uint i = 0; i < pool.length(); i++)
    {
        int bonusType = pool[i];
        uint cost = ArmorPerkCost(bonusType);
        if(cost == 0 || int(cost) > freeSlots)
            continue;

        candidates.insertLast(bonusType);
    }

    if(candidates.length() == 0)
        return 0;

    return candidates[Random(0, candidates.length() - 1)];
}

int PickWeightedArmorPerkType(Item@ it)
{
    int[]@ pool = @ArmorPerkPool;
    if(it.GetProtoId() >= 725 && it.GetProtoId() <= 741)
        @pool = @HelmetPerkPool;

    if(pool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    int[] candidates;
    uint totalWeight = 0;
    for(uint i = 0; i < pool.length(); i++)
    {
        int bonusType = pool[i];
        uint cost = ArmorPerkCost(bonusType);
        if(cost == 0 || int(cost) > freeSlots)
            continue;

        uint weight = UpgradePerkRollWeight(cost);
        if(weight == 0)
            continue;

        candidates.insertLast(bonusType);
        totalWeight += weight;
    }

    if(candidates.length() == 0 || totalWeight == 0)
        return 0;

    uint roll = uint(Random(1, int(totalWeight)));
    for(uint i = 0; i < candidates.length(); i++)
    {
        uint weight = UpgradePerkRollWeight(ArmorPerkCost(candidates[i]));
        if(roll <= weight)
            return candidates[i];
        roll -= weight;
    }

    return candidates[candidates.length() - 1];
}

bool TryApplyRandomArmorPerkUniform(Item@ it)
{
    int perkType = PickUniformArmorPerkType(it);
    if(perkType == 0)
        return false;

    uint cost = ArmorPerkCost(perkType);
    if(cost == 0)
        return false;

    return TryApplyPerk(it, perkType, RollArmorBonusValue(perkType), cost);
}

bool TryApplyRandomArmorPerkWeighted(Item@ it)
{
    int perkType = PickWeightedArmorPerkType(it);
    if(perkType == 0)
        return false;

    uint cost = ArmorPerkCost(perkType);
    if(cost == 0)
        return false;

    return TryApplyPerk(it, perkType, RollArmorBonusValue(perkType), cost);
}

uint NormalizePerkMask(uint mask, uint count)
{
    if(count == 0)
        return 0;
    if(count >= 32)
        return mask;
    return mask & ((uint(1) << int(count)) - uint(1));
}

int PickUniformArmorPerkTypeFromMask(Item@ it, uint mask)
{
    int[]@ pool = @ArmorPerkPool;
    if(it.GetProtoId() >= 725 && it.GetProtoId() <= 741)
        @pool = @HelmetPerkPool;

    if(pool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    uint normalizedMask = NormalizePerkMask(mask, pool.length());
    if(normalizedMask == 0)
        return 0;

    int[] candidates;
    for(uint i = 0; i < pool.length(); i++)
    {
        uint bit = (uint(1) << int(i));
        if((normalizedMask & bit) == 0)
            continue;

        int bonusType = pool[i];
        uint cost = ArmorPerkCost(bonusType);
        if(cost == 0 || int(cost) > freeSlots)
            continue;

        candidates.insertLast(bonusType);
    }

    if(candidates.length() == 0)
        return 0;

    return candidates[Random(0, candidates.length() - 1)];
}

bool TryApplyRandomArmorPerkUniformFromMask(Item@ it, uint mask)
{
    int perkType = PickUniformArmorPerkTypeFromMask(it, mask);
    if(perkType == 0)
        return false;

    uint cost = ArmorPerkCost(perkType);
    if(cost == 0)
        return false;

    return TryApplyPerk(it, perkType, RollArmorBonusValue(perkType), cost);
}

int[] WeaponPerkPool =
{
    UPGRADE_WEAPON_PERK_ACCURATE,
    UPGRADE_WEAPON_PERK_PENETRATE,
    UPGRADE_WEAPON_PERK_COMMANDO,
    UPGRADE_WEAPON_PERK_FAST_RELOAD,
    UPGRADE_WEAPON_PERK_DOUBLE_MAGAZINE,
    UPGRADE_WEAPON_PERK_ENHANCED_DAMAGE,
    UPGRADE_WEAPON_PERK_AP_BOOST,
    UPGRADE_WEAPON_PERK_CRITICAL_POWER,
    UPGRADE_WEAPON_PERK_SILENT_HILL_MONSTER,
    UPGRADE_WEAPON_PERK_BLAST,
    UPGRADE_WEAPON_PERK_PERSISTENT,
    UPGRADE_WEAPON_PERK_INCREASED_RANGE
};

bool TryApplyRandomWeaponPerk(Item@ it, bool isCrafting = false, uint forcedSlotCost = 0)
{
    if(!valid(it))
        return false;

    uint attempts = 0;
    while(attempts < 100)
    {
        int perkType = WeaponPerkPool[Random(0, WeaponPerkPool.length() - 1)];
        uint cost = (forcedSlotCost > 0 ? forcedSlotCost : WeaponUpgradePerkCost(perkType));
        int value = WeaponUpgradePerkBaseValue(perkType);

        if(TryApplyPerk(it, perkType, value, cost))
            return true;

        attempts++;
    }
    return false;
}

int PickUniformWeaponPerkType(Item@ it, uint forcedSlotCost = 0)
{
    if(!valid(it) || WeaponPerkPool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    int[] candidates;
    for(uint i = 0; i < WeaponPerkPool.length(); i++)
    {
        int perkType = WeaponPerkPool[i];
        uint cost = (forcedSlotCost > 0 ? forcedSlotCost : WeaponUpgradePerkCost(perkType));
        if(cost == 0 || int(cost) > freeSlots)
            continue;

        candidates.insertLast(perkType);
    }

    if(candidates.length() == 0)
        return 0;

    return candidates[Random(0, candidates.length() - 1)];
}

int PickWeightedWeaponPerkType(Item@ it, uint forcedSlotCost = 0)
{
    if(!valid(it) || WeaponPerkPool.length() == 0)
        return 0;

    int freeSlots = UpgradeFreeSlots(it);
    if(freeSlots <= 0)
        return 0;

    int[] candidates;
    uint totalWeight = 0;
    for(uint i = 0; i < WeaponPerkPool.length(); i++)
    {
        int perkType = WeaponPerkPool[i];
        uint cost = (forcedSlotCost > 0 ? forcedSlotCost : WeaponUpgradePerkCost(perkType));
        if(cost == 0 || int(cost) > freeSlots)
            continue;

        uint weight = UpgradePerkRollWeight(cost);
        if(weight == 0)
            continue;

        candidates.insertLast(perkType);
        totalWeight += weight;
    }

    if(candidates.length() == 0 || totalWeight == 0)
        return 0;

    uint roll = uint(Random(1, int(totalWeight)));
    for(uint i = 0; i < candidates.length(); i++)
    {
        uint cost = (forcedSlotCost > 0 ? forcedSlotCost : WeaponUpgradePerkCost(candidates[i]));
        uint weight = UpgradePerkRollWeight(cost);
        if(roll <= weight)
            return candidates[i];
        roll -= weight;
    }

    return candidates[candidates.length() - 1];
}

bool TryApplyRandomWeaponPerkUniform(Item@ it, bool isCrafting = false, uint forcedSlotCost = 0)
{
    int perkType = PickUniformWeaponPerkType(it, forcedSlotCost);
    if(perkType == 0)

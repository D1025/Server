void TryRollPerksToCap(Item@ it, bool weapon, bool isCrafting = false, bool forceSingleSlotWeaponPerks = true)
{
    uint safety = 0;
    if(weapon)
    {
        // New baseline: weapons start with 3 random weapon perks.
        int targetPerks = MIN(int(BASE_WEAPON_PERKS), UpgradeQualitySlots(it));
        uint forcedSlotCost = (forceSingleSlotWeaponPerks ? 1 : 0);
        while(UpgradePerksCount(it) < targetPerks && safety < 200)
        {
            if(!TryApplyRandomWeaponPerkUniform(it, isCrafting, forcedSlotCost))
                break;
            safety++;
        }
    }
    else
    {
        int quality = UpgradeQualitySlots(it);
        int targetPerks = MIN(UPGRADE_MAX_PERKS, quality);
        while(UpgradePerksCount(it) < targetPerks && safety < 100)
        {
            if(!TryApplyRandomArmorPerkUniform(it))
                break;
            safety++;
        }
    }
}

void TryRollPerksToCount(Item@ it, bool weapon, uint targetPerks, bool isCrafting = false)
{
    if(!valid(it))
        return;

    targetPerks = MIN(targetPerks, UPGRADE_MAX_SLOTS);
    uint safety = 0;
    while(UpgradePerksCount(it) < int(targetPerks) && safety < 300)
    {
        bool applied = weapon ? TryApplyRandomWeaponPerkUniform(it, isCrafting) : TryApplyRandomArmorPerkUniform(it);
        if(!applied)
            break;
        safety++;
    }
}

void TryRollPerksToCountWeighted(Item@ it, bool weapon, uint targetPerks, bool isCrafting = false)
{
    if(!valid(it))
        return;

    targetPerks = MIN(targetPerks, UPGRADE_MAX_SLOTS);
    uint safety = 0;
    while(UpgradePerksCount(it) < int(targetPerks) && safety < 300)
    {
        bool applied = weapon ? TryApplyRandomWeaponPerkWeighted(it, isCrafting) : TryApplyRandomArmorPerkWeighted(it);
        if(!applied)
            break;
        safety++;
    }
}

// Returns quality level (0..5), not number of active perks.
uint BonusNumber(Item@ it)
{
    return uint(UpgradeBaseQualitySlots(it));
}

void AddBonusOrNot(Item@ it)
{
    if(!valid(it))
        return;

    if(it.GetType() == ITEM_TYPE_WEAPON && !it.IsStackable())
    {
        uint quality = QualityByRoll_Default(Random(0, 99));
        quality = EnsureWeaponBaseQuality(quality);
        ResetUpgradeSlots(it, quality);
        TryFillUpgradeSlotsRandomly(it, true);
    }
    else if(it.GetType() == ITEM_TYPE_ARMOR)
    {
        uint quality = QualityByRoll_Default(Random(0, 99));
        ResetUpgradeSlots(it, quality);
        TryFillUpgradeSlotsRandomly(it, false);
    }
}


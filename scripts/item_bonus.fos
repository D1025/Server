void AddBonuses(Item@ it, string@ crafter)
{
    if(!valid(it))
        return;

    if(it.GetType() == ITEM_TYPE_WEAPON && !it.IsStackable())
    {
        uint quality = QualityByRoll_Crafted(Random(0, 99));
        quality = EnsureWeaponBaseQuality(quality);
        ResetUpgradeSlots(it, quality);
        uint craftedPerks = CraftedPerksByRoll(Random(0, 99));
        TryRollPerksToCountWeighted(it, true, craftedPerks, true);
        SetLexem(it, "$crafter", crafter);
    }
    else if(it.GetType() == ITEM_TYPE_ARMOR)
    {
        uint quality = QualityByRoll_Crafted(Random(0, 99));
        ResetUpgradeSlots(it, quality);
        uint craftedPerks = CraftedPerksByRoll(Random(0, 99));
        TryRollPerksToCountWeighted(it, false, craftedPerks);
        SetLexem(it, "$crafter", crafter);
    }
}

void AddBonusHinkley(Item@ it)
{
    AddBonusHinkley(it, 0, 0);
}

void AddBonusHinkley(Item@ it, int preferredWeaponPerk, int preferredArmorPerk)
{
    if(!valid(it))
        return;

    if(it.GetType() == ITEM_TYPE_WEAPON && !it.IsStackable())
    {
        uint quality = MIN(4, QualityByRoll_LowSpecial(Random(0, 99)));
        quality = EnsureWeaponBaseQuality(quality);
        ResetUpgradeSlots(it, quality);

        int targetPerks = MIN(int(BASE_WEAPON_PERKS), UpgradeQualitySlots(it));
        bool preferredApplied = false;
        if(preferredWeaponPerk != 0 && IsWeaponUpgradePerk(preferredWeaponPerk))
            preferredApplied = TryApplyPerk(it, preferredWeaponPerk, WeaponUpgradePerkBaseValue(preferredWeaponPerk), 1);

        uint safety = 0;
        while(UpgradePerksCount(it) < targetPerks && safety < 200)
        {
            if(!TryApplyRandomWeaponPerkUniform(it, false, 1))
                break;
            safety++;
        }

        if(!preferredApplied && preferredWeaponPerk != 0 && IsWeaponUpgradePerk(preferredWeaponPerk) && UpgradePerksCount(it) == 0)
            TryApplyPerk(it, preferredWeaponPerk, WeaponUpgradePerkBaseValue(preferredWeaponPerk), 1);
    }
    else if(it.GetType() == ITEM_TYPE_ARMOR)
    {
        uint quality = MIN(4, QualityByRoll_LowSpecial(Random(0, 99)));
        ResetUpgradeSlots(it, quality);

        if(preferredArmorPerk != 0 && IsArmorBonusType(preferredArmorPerk))
            TryApplyPerk(it, preferredArmorPerk, RollArmorBonusValue(preferredArmorPerk), ArmorPerkCost(preferredArmorPerk));

        int targetPerks = MIN(UPGRADE_MAX_PERKS, UpgradeQualitySlots(it));
        uint safety = 0;
        while(UpgradePerksCount(it) < targetPerks && safety < 100)
        {
            if(!TryApplyRandomArmorPerkUniform(it))
                break;
            safety++;
        }
    }
}

void AddBonusHinkleySelected(Item@ it, uint weaponMask, uint armorMask)
{
    if(!valid(it))
        return;

    if(it.GetType() == ITEM_TYPE_WEAPON && !it.IsStackable())
    {
        uint quality = MIN(4, QualityByRoll_LowSpecial(Random(0, 99)));
        quality = EnsureWeaponBaseQuality(quality);
        ResetUpgradeSlots(it, quality);

        int targetPerks = MIN(int(BASE_WEAPON_PERKS), UpgradeQualitySlots(it));
        uint safety = 0;
        while(UpgradePerksCount(it) < targetPerks && safety < 200)
        {
            bool applied = false;
            if(weaponMask != 0)
                applied = TryApplyRandomWeaponPerkUniformFromMask(it, weaponMask, false, 1);
            if(!applied)
                applied = TryApplyRandomWeaponPerkUniform(it, false, 1);
            if(!applied)
                break;
            safety++;
        }
    }
    else if(it.GetType() == ITEM_TYPE_ARMOR)
    {
        uint quality = MIN(4, QualityByRoll_LowSpecial(Random(0, 99)));
        ResetUpgradeSlots(it, quality);

        int targetPerks = MIN(UPGRADE_MAX_PERKS, UpgradeQualitySlots(it));
        uint safety = 0;
        while(UpgradePerksCount(it) < targetPerks && safety < 100)
        {
            bool applied = false;
            if(armorMask != 0)
                applied = TryApplyRandomArmorPerkUniformFromMask(it, armorMask);
            if(!applied)
                applied = TryApplyRandomArmorPerkUniform(it);
            if(!applied)
                break;
            safety++;
        }
    }
}

void AddBonuses(Item@ it, int magic)
{
    if(!valid(it))
        return;

    uint quality = uint(CLAMP(magic, 0, UPGRADE_MAX_SLOTS));
    if(it.GetType() == ITEM_TYPE_WEAPON && !it.IsStackable())
    {
        ResetUpgradeSlots(it, quality);
        // Cheat-spawned items should consume the full slot budget and bias toward cheaper perks.
        TryFillUpgradeSlotsWeighted(it, true, true);
    }
    else if(it.GetType() == ITEM_TYPE_ARMOR)
    {
        ResetUpgradeSlots(it, quality);
        TryFillUpgradeSlotsWeighted(it, false);
    }
}

void AddArmorBonus(Item@ it, int number)
{
    if(!valid(it) || it.GetType() != ITEM_TYPE_ARMOR)
        return;
    TryApplyRandomArmorPerk(it);
}

void AddWeaponBonus(Item@ it, int number, bool isCrafting = false)
{
    if(!valid(it) || it.GetType() != ITEM_TYPE_WEAPON || it.IsStackable())
        return;
    TryApplyRandomWeaponPerk(it, isCrafting);
}

bool IsBonusExcluded(bool isCrafting, int bonusType)
{
    if(!isCrafting)
        return false;

    // Kept for compatibility with older callers; not used in v2 roll.
    if(bonusType == BONUS_WEAPON_MAX_AP)
        return true;

    return false;
}

int checkBonus(Item@ it, int bonusType)
{
    if(!valid(it))
        return 0;

    if(it.GetType() == ITEM_TYPE_WEAPON)
        return UpgradeWeaponBonus(it, bonusType);

    return UpgradeBonusValue(it, bonusType);
}

// Explicit helpers for future UI/workbench implementation.
void SetItemUpgradeQuality(Item@ it, uint slotsCount)
{
    if(!valid(it))
        return;
    ResetUpgradeSlots(it, slotsCount);
}

bool ApplyWeaponUpgradePerk(Item@ it, int perkType)
{
    if(!valid(it) || it.GetType() != ITEM_TYPE_WEAPON || it.IsStackable())
        return false;
    if(!IsWeaponUpgradePerk(perkType))
        return false;
    return TryApplyPerk(it, perkType, WeaponUpgradePerkBaseValue(perkType), WeaponUpgradePerkCost(perkType));
}

bool ApplyArmorUpgradePerk(Item@ it, int perkType, int value)
{
    if(!valid(it) || it.GetType() != ITEM_TYPE_ARMOR)
        return false;
    if(UpgradeItemIsHelmet(it))
        return false;
    if(!IsArmorBonusType(perkType))
        return false;
    return TryApplyPerk(it, perkType, value, ArmorPerkCost(perkType));
}

void SetItemCustomName(Item@ it, string& name)
{
    if(!valid(it))
        return;

    if(name.length() == 0)
        UnsetLexem(it, ITEM_LEXEM_CUSTOM_NAME);
    else
        SetLexem(it, ITEM_LEXEM_CUSTOM_NAME, name);
}

uint GetItemLegendary(Item@ it)
{
    if(!valid(it) || !IsLexem(it, ITEM_LEXEM_LEGENDARY))
        return 0;

    int value = 0;
    string raw = GetLexem(it, ITEM_LEXEM_LEGENDARY);
    if(!StrToInt(raw, value))
        return 0;

    return uint(MAX(value, 0));
}

void SetItemLegendary(Item@ it, uint value)
{
    if(!valid(it))
        return;
    SetLexem(it, ITEM_LEXEM_LEGENDARY, "" + value);
}

void AddItemLegendary(Item@ it, uint delta)
{
    if(!valid(it) || delta == 0)
        return;
    SetItemLegendary(it, GetItemLegendary(it) + delta);
}

bool IsItemLegendaryReady(Item@ it)
{
    return GetItemLegendary(it) >= LEGENDARY_TARGET;
}

#endif // __ITEM_BONUS__
